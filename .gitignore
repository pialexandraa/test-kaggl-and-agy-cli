#   project is restricted to a single Python version.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   this file may be deleted or modified.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact version information.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact version information.
